    <div class="carousel-dots" id="carouselDots"></div>
  </div>
</section>

{% block scripts %}
<script>
// Store original label on each expand button
document.querySelectorAll('.logo-expand-inline').forEach(btn => {
  btn.dataset.collapsed = btn.textContent;
});

function toggleSection(gridId, btn) {
  const grid = document.getElementById(gridId);
  const hidden = grid.querySelectorAll('.logo-hidden');
  const isExpanded = hidden[0]?.classList.contains('show');
  hidden.forEach(el => el.classList.toggle('show'));
  btn.textContent = isExpanded ? btn.dataset.collapsed : 'Show fewer';
}
</script>
<script>
// Testimonial Carousel
let currentSlide = 0;
const track = document.getElementById('testimonialTrack');
const slides = track.querySelectorAll('.testimonial-card');
const totalSlides = slides.length;
const dotsContainer = document.getElementById('carouselDots');

// Build dots
for (let i = 0; i < totalSlides; i++) {
  const dot = document.createElement('button');
  dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
  dot.onclick = () => goToSlide(i);
  dotsContainer.appendChild(dot);
}

function goToSlide(n) {
  currentSlide = n;
  track.style.transform = `translateX(-${currentSlide * 100}%)`;
  dotsContainer.querySelectorAll('.carousel-dot').forEach((d, i) => {
    d.classList.toggle('active', i === currentSlide);
  });
}

function moveTestimonial(dir) {
  let next = currentSlide + dir;
  if (next < 0) next = totalSlides - 1;
  if (next >= totalSlides) next = 0;
  goToSlide(next);
}
</script>
{% endblock %}
