{% block scripts %}
<script src="/js/data.js?v={{ "" | cacheBust }}"></script>
<script>
// ---- Lazy transcript loading ----
const transcriptCache = {};
async function fetchTranscript(ep) {
  const id = ep.transcriptId;
  if (transcriptCache[id]) return transcriptCache[id];
  try {
    const resp = await fetch('/transcripts/' + id + '.json');
    const data = await resp.json();
    transcriptCache[id] = data.transcript;
    return data.transcript;
  } catch (e) { return null; }
}

// ---- Helpers ----
function formatDate(d) {
  if (!d) return '';
  try { return new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }); }
  catch(e) { return d; }
}

const ABBREVS = /(?:Dr|Mr|Mrs|Ms|Prof|Sr|Jr|St|vs|etc|e\.g|i\.e|Vol|Ep|Inc|Ltd|M\.?D|Ph\.?D|D\.?P\.?T|P\.?A|R\.?D\.?N|O\.?T|P\.?T|J\.?D)\s*$/i;
function truncateAtSentence(text, maxChars) {
  if (!text || text.length <= maxChars) return text;
  const firstPara = text.split('\n\n')[0];
  if (firstPara.length <= maxChars) return firstPara;
  let lastGoodEnd = -1;
  for (let i = maxChars * 0.5; i < Math.min(firstPara.length, maxChars * 1.5); i++) {
    const ch = firstPara[i];
    if ((ch === '.' || ch === '!' || ch === '?') && (i + 1 >= firstPara.length || firstPara[i + 1] === ' ' || firstPara[i + 1] === '\n')) {
      const before = firstPara.substring(Math.max(0, i - 15), i + 1);
      if (!ABBREVS.test(before)) {
        lastGoodEnd = i + 1;
        if (i >= maxChars * 0.8) break;
      }
    }
  }
  if (lastGoodEnd > 0) return firstPara.substring(0, lastGoodEnd).trim();
  const cut = firstPara.substring(0, maxChars).lastIndexOf(' ');
  return firstPara.substring(0, cut > 0 ? cut : maxChars).trim() + '...';
}

function resolveGuestImage(name) {
  let n = name.replace(/^(Dr\.?|Prof\.?|Professor)\s+/i, '');
  let prev;
  do {
    prev = n;
    n = n.replace(/[,\s]+(M\.?D\.?|Ph\.?D\.?|D\.?P\.?T\.?|D\.?O\.?|P\.?A\.?\-?C?|R\.?D\.?N\.?|O\.?T\.?|P\.?T\.?|J\.?D\.?|LICSW|NCPT|ATC|MS|MA|MPT|DMSC|MRCPsych|DDS|D\.?C\.?|FACP|FACS|FAANS|FAAFP|FAAN|FAMSSM|FACOG|FRCPC|IFMCP|ABIHM|CCSP|CEDS-S|FAED|CHT|CYT|CHC|CMTPT|COMT|NCS|OCS|CES|MHCM)\.?\s*$/i, '');
  } while (n !== prev);
  n = n.replace(/[,.\s]+$/, '').trim().toLowerCase();
  return GUEST_IMAGES[n] || null;
}

function buildAvatarHtml(ep) {
  if (!ep.guests || ep.guests.length === 0) return '';
  const resolved = ep.guests.map(g => resolveGuestImage(g)).filter(Boolean);
  if (resolved.length === 0) return '';
  const MAX_SHOW = 2;
  const isMulti = resolved.length > 1;
  let html = resolved.slice(0, MAX_SHOW).map(src =>
    `<img class="guest-avatar-img" src="${src}" alt="" loading="lazy">`
  ).join('');
  if (resolved.length > MAX_SHOW) {
    html += `<span class="guest-avatar-overflow">+${resolved.length - MAX_SHOW}</span>`;
  }
  return `<div class="guest-avatars${isMulti ? ' multi' : ''}">${html}</div>`;
}

function cleanTitle(t) {
  return t.replace(/\s*\((?:Ep|EP|BEN)\s*\d+\)\s*$/, '').replace(/^\d+\.\s+/, '').trim();
}

// ---- Latest Episode ----
function buildLatest(ep, idx) {
  const guestStr = ep.guests && ep.guests.length ? ep.guests.join(', ') : '';
  const guestLabel = guestStr ? `<span class="featured-guest-inline">${guestStr}</span>` : '';

  return `
  <div class="featured-top-bar">
    ${ep.num ? `<div class="featured-latest-num">${ep.num}</div>` : ''}
    ${buildAvatarHtml(ep)}
    ${guestLabel}
  </div>
  <div class="featured-bottom">
    <div>
      <h2 style="margin:0;"><a href="#" onclick="openLatestModal(${idx});return false;" style="color:inherit;text-decoration:none;">${cleanTitle(ep.title)}</a></h2>
    </div>
    <p class="featured-description">${truncateAtSentence(ep.description, 350)}</p>
    ${ep.audioUrl ? `<div style="margin-bottom: 20px;"><audio controls preload="none" style="width:100%; border-radius:28px;"><source src="${ep.audioUrl}" type="audio/mpeg">Your browser does not support audio.</audio></div>` : ''}
    <div class="featured-actions">
      <a href="#" onclick="openLatestModal(${idx});return false;" class="btn btn-primary">Full Episode Details</a>
      ${ep.videoUrl ? `<a href="#" onclick="openLatestVideo(${idx});return false;" class="btn btn-secondary btn-watch-featured"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:-2px;margin-right:4px;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>Watch</a>` : ''}
      <a href="/podcast-episodes/" class="btn btn-secondary">Browse All Episodes</a>
    </div>
  </div>`;
}

const sorted = EPISODES.slice().sort((a,b) => new Date(b.date) - new Date(a.date));
const latestIdx = EPISODES.indexOf(sorted[0]);
document.getElementById('latestEpisode').innerHTML = buildLatest(sorted[0], latestIdx);

// ---- Featured Episodes ----
const featuredNums = [184, 170, 155, 140, 120, 100];
const featured = featuredNums.map(n => EPISODES.find(e => e.num === n)).filter(Boolean).slice(0, 3);
if (featured.length < 3) {
  const picks = sorted.filter((ep, i) => i > 0 && i < 30);
  while (featured.length < 3 && picks.length > 0) {
    const pick = picks.splice(Math.floor(picks.length / 2), 1)[0];
    if (pick && !featured.find(e => e.num === pick.num)) featured.push(pick);
  }
}

function buildCard(ep) {
  const epNum = ep.num ? `<div class="ep-number">${ep.num}</div>` : '';
  const guestStr = ep.guests && ep.guests.length ? ep.guests.join(', ') : '';
  const isMulti = ep.guests && ep.guests.length > 1;
  const guestLine = guestStr ? `<div class="guest-name${isMulti ? ' multi-guest' : ''}">with ${guestStr}</div>` : '';
  const meta = formatDate(ep.date);
  return `
  <article class="episode-card" onclick="window.location.href='/podcast-episodes/?ep=${ep.num}'" style="cursor:pointer;">
    <div class="card-header">
      ${epNum}
      <div class="card-header-text">
        ${guestLine}
        <h3>${cleanTitle(ep.title)}</h3>
      </div>
      ${buildAvatarHtml(ep)}
    </div>
    <div class="card-body">
      <p class="card-description">${truncateAtSentence(ep.description, 200)}</p>
    </div>
    <div class="card-footer">
      <span class="card-meta">${meta}</span>
      <div class="card-footer-actions">
        ${ep.videoUrl ? `<span class="btn-watch" onclick="event.stopPropagation();openFeaturedVideo(${EPISODES.indexOf(ep)})">Watch</span>` : ''}
        <span class="btn-listen">Listen</span>
      </div>
    </div>
  </article>`;
}

document.getElementById('featuredGrid').innerHTML = featured.map(buildCard).join('');

// Dynamic episode count
const epCount = EPISODES.length;
document.getElementById('viewAllBtn').textContent = `View All ${epCount} Episodes`;
document.getElementById('epCountCta').textContent = epCount;

// ---- Episode Detail Modal ----
const TAG_COLORS = {
  'EDS': '#4a2d7a', 'POTS': '#236a8a', 'MCAS': '#9d2a6b',
  'Pain': '#9d4a2a', 'Nutrition': '#2a7a4a', 'Mental Health': '#6b4a9d',
  'Exercise': '#2a5c9d', 'Diagnosis': '#7a5c2a', 'Treatment': '#2a9d8f',
  'Neurology': '#4a4a9d', 'Surgery': '#7a2a2a', 'Genetics': '#5c7a2a',
  'Hypermobility': '#4a2d7a', 'Research': '#2a4a7a',
};

function getSocialIcon(url, size) {
