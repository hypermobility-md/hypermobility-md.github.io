---
layout: base.njk
---

{% include "podcast-subnav.njk" %}

<div class="episode-detail">
  <!-- Header -->
  <div class="episode-detail-header">
    <div class="container">
      <div class="episode-detail-header-inner">
        <div class="episode-detail-header-text">
          {% if num %}<div class="episode-detail-num">Episode {{ num }}</div>{% endif %}
          <h1>{{ title | cleanTitle }}</h1>
          {% if guests and guests.length %}
          <div class="episode-detail-guests">
            with
            {% for g in guests %}
              {%- set gKey = g | guestKey -%}
              {%- if guestData.profiles[gKey] -%}
                <a href="/guests/{{ gKey | slug }}/">{{ g }}</a>
              {%- else -%}
                {{ g }}
              {%- endif -%}
              {%- if not loop.last %}, {% endif -%}
            {% endfor %}
          </div>
          {% endif %}
          <div class="episode-detail-meta">
            {% if date %}{{ date | formatDate }}{% endif %}
            {% if date and duration %} &middot; {% endif %}
            {% if duration %}{{ duration }}{% endif %}
          </div>
          {% if tags and tags.length %}
          <div class="episode-detail-header-tags">
            {% for tag in tags %}
            <a href="/podcast-episodes/?tag={{ tag | urlencode }}" class="tag-chip tag-chip-header">{{ tag }}</a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% if guests and guests.length %}
        <div class="episode-detail-avatars">
          {% for g in guests %}
            {%- set gKey = g | guestKey -%}
            {%- set img = guestData.images[gKey] -%}
            {% if img %}
              {%- if guestData.profiles[gKey] -%}
                <a href="/guests/{{ gKey | slug }}/" title="{{ g }}"><img class="guest-avatar-img" src="{{ img }}" alt="{{ g }}"></a>
              {%- else -%}
                <img class="guest-avatar-img" src="{{ img }}" alt="{{ g }}">
              {%- endif -%}
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="container episode-detail-body">

    <!-- Description -->
    <section class="episode-section">
      <h2>Description</h2>
      <div class="episode-detail-description">
        {{ description | markdownify | safe }}
      </div>
    </section>

    <!-- Audio & Watch Actions -->
    {% if audioUrl or videoUrl %}
    <section class="episode-section">
      <div class="episode-action-buttons">
        {% if audioUrl %}
        <div style="flex:1;min-width:0;">
          <h2>Listen</h2>
          <audio controls preload="none" style="width: 100%;">
            <source src="{{ audioUrl }}" type="audio/mpeg">
            Your browser does not support audio.
          </audio>
        </div>
        {% endif %}
        {% if videoUrl %}
        <div>
          <a href="#episode-video" class="btn btn-secondary btn-watch-inline" onclick="document.getElementById('episode-video').scrollIntoView({behavior:'smooth',block:'center'});return false;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:-2px;margin-right:4px;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            Watch
          </a>
        </div>
        {% endif %}
      </div>
    </section>
    {% endif %}

    <!-- Video Embed -->
    {% if videoUrl %}
    <section class="episode-section" id="episode-video">
      <h2>Watch</h2>
      <div class="episode-video-embed">
        <iframe src="{{ videoUrl | youtubeEmbed }}" allowfullscreen loading="lazy"></iframe>
      </div>
    </section>
    {% endif %}

    <!-- Snippets -->
    {% if snippets and snippets.length %}
    <section class="episode-section">
      <h2>Snippets</h2>
      <div class="snippets-grid">
        {% for url in snippets %}
        <div class="snippet-embed">
          <iframe src="{{ url | youtubeEmbed }}" allowfullscreen loading="lazy"></iframe>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <!-- Guest Cards -->
    {% if guests and guests.length %}
    <section class="episode-section">
      <h2>Guests</h2>
      <div class="episode-guest-cards">
        {% for g in guests %}
          {%- set gKey = g | guestKey -%}
          {%- set img = guestData.images[gKey] -%}
          {%- set profile = guestData.profiles[gKey] -%}
          <div class="guest-card">
            <div class="guest-card-header">
              {% if img %}<img class="guest-card-img" src="{{ img }}" alt="{{ g }}">{% endif %}
              <h3>
                {%- if profile -%}
                  <a href="/guests/{{ gKey | slug }}/" style="color:inherit;text-decoration:none;">{{ g }}</a>
                {%- else -%}
                  {{ g }}
                {%- endif -%}
              </h3>
            </div>
            {% if profile and profile.affiliation %}
            <div class="guest-card-affiliation">{{ profile.affiliation }}</div>
            {% endif %}
            {% if profile and profile.bio %}
            <div class="guest-card-bio">{{ profile.bio }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <!-- Transcript -->
    {% if content | trim %}
    <section class="episode-section">
      <h2>Transcript</h2>
      <div class="transcript-content">{{ content | safe }}</div>
    </section>
    {% endif %}

    <!-- Navigation -->
    {% set adj = collections.episodes | adjacentEpisodes(page.inputPath) %}
    <nav class="episode-nav">
      <a href="/podcast-episodes/" class="episode-nav-back">&larr; Back to All Episodes</a>
      <div class="episode-nav-prevnext">
        {% if adj.prev and adj.prev.url %}
        <a href="{{ adj.prev.url }}" class="episode-nav-link">&larr; {% if adj.prev.data.num %}Ep {{ adj.prev.data.num }}{% else %}{{ adj.prev.data.title | cleanTitle | truncate(30, true, "...") }}{% endif %}</a>
        {% endif %}
        {% if adj.next and adj.next.url %}
        <a href="{{ adj.next.url }}" class="episode-nav-link">{% if adj.next.data.num %}Ep {{ adj.next.data.num }}{% else %}{{ adj.next.data.title | cleanTitle | truncate(30, true, "...") }}{% endif %} &rarr;</a>
        {% endif %}
      </div>
    </nav>

  </div>
</div>
