<!DOCTYPE html>
<html lang="en" data-theme="purple">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Hypermobility MD</title>
  {% if description %}<meta name="description" content="{{ description | truncate(160, true, '...') }}">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  {% if extraCss %}<link rel="stylesheet" href="/css/{{ extraCss }}">{% endif %}
  <script src="https://www.google.com/recaptcha/api.js?render=6LejW5AsAAAAACTV9UzbWn_qHvRQXXH6oFtMxqhe" defer></script>
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

{% include "nav.njk" %}

{{ content | safe }}

{% include "footer.njk" %}

{% block scripts %}{% endblock %}
</body>
</html>
