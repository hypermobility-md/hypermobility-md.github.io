<!DOCTYPE html>
<html lang="en" data-theme="purple">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% if not noAnalytics %}
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-W4FZD9G9');</script>
  <!-- End Google Tag Manager -->
  {% endif %}

  {% if noAnalytics %}
  {# Sensitive form pages: send only the origin (not the full path) as the referer,
     so the form's URL is never passed to the next page's analytics. Forms already
     load no GTM/GA at all; this closes the reverse (leaving-the-form) path too. #}
  <meta name="referrer" content="origin">
  {% endif %}
  {%- set _pageTitle = (seoOverrides.ogTitle if seoOverrides) or title -%}
  {%- set _pageDesc = (seoOverrides.ogDescription if seoOverrides) or description -%}
  <title>{{ _pageTitle }} — Hypermobility MD</title>
  {% if _pageDesc %}<meta name="description" content="{{ _pageDesc | truncate(160, true, '...') }}">{% endif %}

  {# SEO #}
  <link rel="canonical" href="{{ canonicalUrl or (site.url + page.url) }}">
  {% include "seo/open-graph.njk" %}
  {% include "seo/json-ld.njk" %}

  {# Podcast RSS feed #}
  <link rel="alternate" type="application/rss+xml" title="{{ site.podcastName }}" href="{{ site.podcastFeedUrl }}">

  {# Favicons #}
  <link rel="icon" href="/favicon.ico" sizes="48x48">
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="icon" type="image/png" sizes="96x96" href="/assets/favicon-96x96.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/assets/favicon-48x48.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-title" content="Bendy Bodies">
  <link rel="manifest" href="/site.webmanifest">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>
  <style>{{ "styles.css" | inlineCssFile | safe }}</style>
  {% if extraCss %}<style>{{ extraCss | inlineCssFile | safe }}</style>{% endif %}
  {% if needsRecaptcha %}
  <script src="https://www.google.com/recaptcha/api.js?render=6LejW5AsAAAAACTV9UzbWn_qHvRQXXH6oFtMxqhe" defer></script>
  {% endif %}
  {% block head %}{% endblock %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
<a href="#main" class="skip-link">Skip to content</a>
{% if not noAnalytics %}
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W4FZD9G9"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
{% endif %}

{% include "nav.njk" %}

<main id="main" tabindex="-1">
{{ content | safe }}
</main>

{% include "footer.njk" %}

<button id="backToTop" class="back-to-top" type="button" aria-label="Back to top">
  <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5"/><path d="m5 12 7-7 7 7"/></svg>
</button>
<script>
(function () {
  var btn = document.getElementById('backToTop');
  if (!btn) return;
  var toggle = function () { btn.classList.toggle('is-visible', window.scrollY > 500); };
  window.addEventListener('scroll', toggle, { passive: true });
  btn.addEventListener('click', function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
  });
  toggle();
})();
</script>

{% block scripts %}{% endblock %}
</body>
</html>
