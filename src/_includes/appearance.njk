---
layout: base.njk
---

{% include "podcast-subnav.njk" %}

<div class="episode-detail">
  <!-- Header -->
  <div class="appearance-detail-header">
    <div class="container">
      <div class="appearance-detail-header-inner">
        <div class="appearance-detail-header-text">
          <div class="appearance-detail-show">{{ showName }}</div>
          <h1>{{ episodeTitle }}</h1>
          <div class="episode-detail-meta">
            {% if date %}{{ date | formatDate }}{% endif %}
          </div>
        </div>
        {% if imageUrl %}
        <div class="appearance-detail-img-wrap">
          <img class="appearance-detail-img" src="{{ imageUrl }}" alt="{{ showName }}" loading="lazy">
        </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="container episode-detail-body">

    <!-- Description -->
    {% if description %}
    <section class="episode-section">
      <h2>About This Episode</h2>
      <div class="episode-detail-description">
        {{ description | markdownify | safe }}
      </div>
    </section>
    {% endif %}

    <!-- Audio & Watch Actions -->
    {% if audioUrl or videoUrl %}
    <section class="episode-section">
      <div class="episode-action-buttons">
        {% if audioUrl %}
        <div style="flex:1;min-width:0;">
          <h2>Listen</h2>
          <audio controls preload="none" style="width: 100%;">
            <source src="{{ audioUrl }}" type="audio/mpeg">
            Your browser does not support audio.
          </audio>
        </div>
        {% endif %}
        {% if videoUrl %}
        <div>
          <a href="#appearance-video" class="btn btn-secondary btn-watch-inline" onclick="document.getElementById('appearance-video').scrollIntoView({behavior:'smooth',block:'center'});return false;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:-2px;margin-right:4px;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            Watch
          </a>
        </div>
        {% endif %}
      </div>
    </section>
    {% endif %}

    <!-- Video Embed -->
    {% if videoUrl %}
    <section class="episode-section" id="appearance-video">
      <h2>Watch</h2>
      <div class="episode-video-embed">
        <iframe src="{{ videoUrl | youtubeEmbed }}" allowfullscreen loading="lazy"></iframe>
      </div>
    </section>
    {% endif %}

    <!-- External Links -->
    <section class="episode-section">
      <h2>Links</h2>
      <div class="appearance-links">
        {% if url %}
        <a href="{{ url }}" target="_blank" rel="noopener" class="btn-subscribe apple">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          {{ type | capitalize }} on {{ showName }}
        </a>
        {% endif %}
        {% if youtubeUrl and youtubeUrl != videoUrl %}
        <a href="{{ youtubeUrl }}" target="_blank" rel="noopener" class="btn-subscribe youtube">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          Watch on YouTube
        </a>
        {% endif %}
      </div>
    </section>

    <!-- Navigation -->
    <nav class="episode-nav">
      <a href="/podcast-appearances/" class="episode-nav-back">&larr; All Guest Appearances</a>
    </nav>

  </div>
</div>
