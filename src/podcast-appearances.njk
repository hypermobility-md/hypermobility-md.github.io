---
layout: base.njk
title: "Guest Appearances"
activePage: "podcast"
extraCss: "podcast-styles.css"
bodyClass: "podcast-page"
podcastSubpage: "appearances"
permalink: /podcast-appearances/
---

{% include "podcast-subnav.njk" %}

<!-- Hero -->
<div class="podcast-page-hero">
  <div class="container">
    <div>
      <h1>Podcast Guest Appearances</h1>
      <p>Dr. Linda Bluestein's guest appearances on other podcasts and shows</p>
    </div>
  </div>
</div>

<!-- Appearances Grid -->
<section class="section">
  <div class="container">
    <div class="appearances-grid">
      {% for appearance in guestAppearances %}
      <div class="appearance-card">
        {% if appearance.imageUrl %}
        <img class="appearance-card-img" src="{{ appearance.imageUrl }}" alt="{{ appearance.showName }}">
        {% endif %}
        <div class="appearance-card-body">
          <h3>{{ appearance.episodeTitle }}</h3>
          <a href="{{ appearance.url }}" target="_blank" rel="noopener" class="btn-listen">{{ "Watch" if appearance.type == "watch" else "Listen" }} &rarr;</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
