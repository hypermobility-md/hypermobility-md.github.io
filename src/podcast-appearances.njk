---
layout: base.njk
title: "Guest Appearances"
activePage: "podcast"
extraCss: "podcast-styles.css"
bodyClass: "podcast-page"
podcastSubpage: "appearances"
permalink: /podcast-appearances/
---

{% include "podcast-subnav.njk" %}

<!-- Hero -->
<div class="podcast-page-hero">
  <div class="container">
    <div>
      <h1>Podcast Guest Appearances</h1>
      <p>Dr. Linda Bluestein's guest appearances on other podcasts and shows</p>
    </div>
  </div>
</div>

<!-- Featured Appearances -->
<section class="section">
  <div class="container">
    <h2 class="appearances-section-heading">Featured</h2>
    <div class="appearances-grid">
      {% for appearance in collections.appearances %}
        {% if appearance.data.featured %}
        <a href="{{ appearance.url }}" class="appearance-card">
          {% if appearance.data.imageUrl %}
          <img class="appearance-card-img" src="{{ appearance.data.imageUrl }}" alt="{{ appearance.data.showName }}">
          {% endif %}
          <div class="appearance-card-body">
            <div class="appearance-card-show">{{ appearance.data.showName }}</div>
            <h3>{{ appearance.data.episodeTitle }}</h3>
            {% if appearance.data.date %}<div class="appearance-card-date">{{ appearance.data.date | formatDate }}</div>{% endif %}
          </div>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- All Other Appearances -->
<section class="section">
  <div class="container">
    <h2 class="appearances-section-heading">Other Appearances</h2>
    <div class="appearances-grid">
      {% for appearance in collections.appearances %}
        {% if not appearance.data.featured %}
        <a href="{{ appearance.url }}" class="appearance-card">
          {% if appearance.data.imageUrl %}
          <img class="appearance-card-img" src="{{ appearance.data.imageUrl }}" alt="{{ appearance.data.showName }}">
          {% endif %}
          <div class="appearance-card-body">
            <div class="appearance-card-show">{{ appearance.data.showName }}</div>
            <h3>{{ appearance.data.episodeTitle }}</h3>
            {% if appearance.data.date %}<div class="appearance-card-date">{{ appearance.data.date | formatDate }}</div>{% endif %}
          </div>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
