<!-- Search & Filter Bar -->
<div class="guest-filter-bar">
  <div class="filter-inner">
    <div class="search-box">
      <span class="search-icon">&#x1F50D;</span>
      <input type="text" id="guestSearch" placeholder="Search guests by name..." autocomplete="off" spellcheck="false">
    </div>
  </div>
</div>

<!-- Alphabet Filter -->
<div class="section" style="padding-top: 32px; padding-bottom: 32px;">
  <div class="container">
    <div class="alpha-filter" id="alphaFilter">
      <button class="alpha-btn active" data-letter="all">All</button>
    </div>
  </div>
</div>

<!-- Guest Grid -->
<div style="background: var(--section-alt); padding-bottom: 64px;">
  <div class="container">
    <div id="guestsContainer">
      <!-- Rendered by JS -->
    </div>
    <div class="no-results" id="noGuests" style="display:none;">
      <h3>No guests found</h3>
      <p>Try a different name or clear the filter.</p>
    </div>
  </div>
</div>

{% block scripts %}
<script src="/js/data.js"></script>
<script>
// Build guest index from episode data
const HOST_PATTERNS = [/linda\s+bluestein/i];
const INVALID_GUESTS = [
  'guest host', 'dance injuries', 'physical therapists', 'chronic pain',
  'multisystemic diseases', 'whealth founders', 'royal ballet',
  'orthopedic surgeon', 'physiotherapist', 'immunologist',
  'psychotherapist', 'anesthesiologist',
];

function isHost(name) { return HOST_PATTERNS.some(p => p.test(name)); }
function isInvalidGuest(name) { const lower = name.toLowerCase(); return INVALID_GUESTS.some(inv => lower.startsWith(inv)); }

function stripCredentials(name) {
  let n = name, prev;
  do {
    prev = n;
    n = n.replace(/[,\s]+(M\.?D\.?|Ph\.?D\.?|D\.?P\.?T\.?|D\.?O\.?|P\.?A\.?-?C?|R\.?D\.?N\.?|O\.?T\.?|P\.?T\.?|J\.?D\.?|LICSW|NCPT|ATC|MS|MA|MPT|DMSC|MRCPsych|DDS)\.?\s*$/i, '');
  } while (n !== prev);
  return n.replace(/[,.\s]+$/, '').trim();
}

function normalizeGuestKey(name) {
  let n = name.replace(/^(Dr\.?|Prof\.?|Professor)\s+/i, '');
  n = stripCredentials(n);
  return n.toLowerCase().replace(/\s+/g, ' ');
}

function getGuestImage(name) {
  let n = name.replace(/^(Dr\.?|Prof\.?|Professor)\s+/i, '');
  n = stripCredentials(n).toLowerCase();
  return GUEST_IMAGES[n] || null;
}

function getSortLastName(name) {
  let n = name.replace(/^(Dr\.?|Prof\.?|Professor)\s+/i, '');
  n = stripCredentials(n);
  const parts = n.split(/\s+/);
  return parts[parts.length - 1];
}

// Build guest map
const tempMap = {};
EPISODES.forEach(ep => {
  if (!ep.guests || ep.guests.length === 0) return;
  ep.guests.forEach(g => {
    if (!g || isHost(g) || isInvalidGuest(g) || g.length < 3) return;
    const key = normalizeGuestKey(g);
    if (key.length < 3) return;
    if (!tempMap[key]) {
      tempMap[key] = { displayName: g, episodes: [] };
    } else {
      const current = tempMap[key].displayName;
      if (g.match(/^Dr\.?\s/i) && !current.match(/^Dr\.?\s/i)) tempMap[key].displayName = g;
      else if (g.length > current.length && !current.match(/^Dr\.?\s/i)) tempMap[key].displayName = g;
    }
    if (!tempMap[key].episodes.find(e => e.title === ep.title)) tempMap[key].episodes.push(ep);
  });
});

const guestMap = {};
Object.values(tempMap).forEach(({ displayName, episodes }) => { guestMap[displayName] = episodes; });

const allGuests = Object.keys(guestMap).sort((a, b) => {
  return getSortLastName(a).toLowerCase().localeCompare(getSortLastName(b).toLowerCase());
});

const letters = [...new Set(allGuests.map(g => getSortLastName(g)[0].toUpperCase()))].sort();

// Build alphabet buttons
const alphaFilter = document.getElementById('alphaFilter');
letters.forEach(l => {
  const btn = document.createElement('button');
  btn.className = 'alpha-btn';
  btn.dataset.letter = l;
  btn.textContent = l;
  alphaFilter.appendChild(btn);
});

let activeLetter = 'all';
let searchQ = '';

function getGuestProfile(name) {
  if (typeof GUEST_PROFILES === 'undefined') return null;
  const key = normalizeGuestKey(name);
  return GUEST_PROFILES[key] || null;
}

function getSocialIcon(url) {
  if (!url) return '';
  const u = url.toLowerCase();
  if (u.includes('linkedin.com')) return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>';
  if (u.includes('twitter.com') || u.includes('x.com')) return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>';
  if (u.includes('instagram.com')) return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>';
  if (u.includes('facebook.com')) return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>';
  if (u.includes('youtube.com') || u.includes('youtu.be')) return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>';
  return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>';
}

function buildGuestCard(name) {
  const episodes = guestMap[name];
  const img = getGuestImage(name);
  const profile = getGuestProfile(name);
  const imgHtml = img ? `<img class="guest-card-img" src="${img}" alt="${name}">` : '';
  const affiliationHtml = profile && profile.affiliation
    ? `<div class="guest-card-affiliation">${profile.affiliation}</div>` : '';
  const bioHtml = profile && profile.bio
    ? `<div class="guest-card-bio">${profile.bio}</div>` : '';
  const websiteHtml = profile && profile.website
    ? `<a href="${profile.website}" target="_blank" rel="noopener" class="guest-card-website" title="Visit website">${getSocialIcon(profile.website)}</a>` : '';
  const epList = episodes.map(ep => {
    const epNum = ep.num ? `<span class="guest-ep-num">Ep ${ep.num}</span> · ` : '';
    const cleanTitle = ep.title.replace(/\s*\((?:Ep|EP|BEN)\s*\d+\)\s*$/, '').replace(/^\d+\.\s+/, '').trim();
    const href = ep.num ? `/podcast-episodes/?ep=${ep.num}` : '#';
    return `<li><a href="${href}" style="color: inherit; text-decoration: none; display: block;">${epNum}${cleanTitle}</a></li>`;
  }).join('');
  const lastName = getSortLastName(name);
  return `
  <div class="guest-card" id="guest-${lastName}">
    <div class="guest-card-header">
      ${imgHtml}
      <h3>${name} ${websiteHtml}</h3>
    </div>
    ${affiliationHtml}
    ${bioHtml}
    <ul class="guest-episodes">${epList}</ul>
  </div>`;
}

function renderGuests() {
  const container = document.getElementById('guestsContainer');
  const noGuests = document.getElementById('noGuests');
  const q = searchQ.toLowerCase();

  let filtered = allGuests.filter(g => {
    const matchSearch = !q || g.toLowerCase().includes(q);
    const lastLetter = getSortLastName(g)[0].toUpperCase();
    const matchLetter = activeLetter === 'all' || lastLetter === activeLetter;
    return matchSearch && matchLetter;
  });

  if (filtered.length === 0) {
    container.innerHTML = '';
    noGuests.style.display = 'block';
    return;
  }
  noGuests.style.display = 'none';

  if (activeLetter === 'all' && !q) {
    const groups = {};
    filtered.forEach(g => {
      const l = getSortLastName(g)[0].toUpperCase();
      if (!groups[l]) groups[l] = [];
      groups[l].push(g);
    });
    container.innerHTML = Object.keys(groups).sort().map(letter => `
      <div class="alpha-section">
        <div class="alpha-section-heading">${letter}</div>
        <div class="guest-index">${groups[letter].map(buildGuestCard).join('')}</div>
      </div>
    `).join('');
  } else {
    container.innerHTML = `<div class="guest-index" style="padding-top: 8px;">${filtered.map(buildGuestCard).join('')}</div>`;
  }
}

// Alpha filter click
document.getElementById('alphaFilter').addEventListener('click', e => {
  const btn = e.target.closest('.alpha-btn');
  if (!btn) return;
  activeLetter = btn.dataset.letter;
  document.querySelectorAll('.alpha-btn').forEach(b => b.classList.toggle('active', b.dataset.letter === activeLetter));
  renderGuests();
});

// Guest search
let timer;
document.getElementById('guestSearch').addEventListener('input', e => {
  clearTimeout(timer);
  timer = setTimeout(() => {
    searchQ = e.target.value;
    activeLetter = 'all';
    document.querySelectorAll('.alpha-btn').forEach(b => b.classList.toggle('active', b.dataset.letter === 'all'));
    renderGuests();
  }, 200);
});

// Handle guest link from episodes page
const urlParams = new URLSearchParams(window.location.search);
const guestParam = urlParams.get('guest');
if (guestParam) {
  document.getElementById('guestSearch').value = guestParam;
  searchQ = guestParam;
}

renderGuests();

// Scroll to guest anchor
if (window.location.hash) {
  const hashId = window.location.hash.slice(1);
  setTimeout(() => {
    const el = document.getElementById(hashId);
    if (el) {
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      el.style.outline = '3px solid var(--primary)';
      el.style.outlineOffset = '4px';
      el.style.borderRadius = 'var(--radius-sm)';
      setTimeout(() => { el.style.outline = ''; el.style.outlineOffset = ''; }, 2000);
    }
  }, 100);
}
</script>
{% endblock %}
