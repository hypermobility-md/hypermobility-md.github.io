<!-- Search & Filter Bar -->
<div class="guest-filter-bar">
  <div class="filter-inner">
    <div class="search-box">
      <span class="search-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
      <input type="text" id="guestSearch" placeholder="Search guests by name..." autocomplete="off" spellcheck="false">
    </div>
  </div>
</div>

{%- set guestGrid = collections.episodes | guestIndex(guestData) %}

<!-- Alphabet Filter -->
<div class="section" style="padding-top: 32px; padding-bottom: 32px;">
  <div class="container">
    <div class="alpha-filter" id="alphaFilter">
      <button class="alpha-btn active" data-letter="all">All</button>
      {%- for letter in guestGrid.letters %}
      <button class="alpha-btn" data-letter="{{ letter }}">{{ letter }}</button>
      {%- endfor %}
    </div>
  </div>
</div>

<!-- Guest Grid (server-rendered; the inline script below only filters this DOM) -->
<div style="background: var(--section-alt); padding-bottom: 64px;">
  <div class="container">
    <div id="guestsContainer">{{ guestGrid.gridHtml | safe }}</div>
    <div class="no-results" id="noGuests" style="display:none;">
      <h3>No guests found</h3>
      <p>Try a different name or clear the filter.</p>
    </div>
  </div>
</div>

{% block scripts %}
<script>
// The guest grid is server-rendered (see scripts/lib/guest-index.cjs). This only
// filters the existing DOM by search box + alphabet, so no episode data or card
// building runs in the browser.
(function () {
  const alphaFilter = document.getElementById("alphaFilter");
  const searchInput = document.getElementById("guestSearch");
  const noGuests = document.getElementById("noGuests");
  const sections = Array.from(document.querySelectorAll(".alpha-section"));
  let activeLetter = "all";
  let searchQ = "";

  function apply() {
    const q = searchQ.toLowerCase().trim();
    let total = 0;
    sections.forEach(sec => {
      let shown = 0;
      sec.querySelectorAll(".guest-card").forEach(card => {
        const matchSearch = !q || card.dataset.name.includes(q);
        const matchLetter = activeLetter === "all" || sec.dataset.letter === activeLetter;
        const ok = matchSearch && matchLetter;
        card.hidden = !ok;
        if (ok) shown++;
      });
      sec.hidden = shown === 0;
      total += shown;
    });
    noGuests.style.display = total === 0 ? "block" : "none";
  }

  alphaFilter.addEventListener("click", e => {
    const btn = e.target.closest(".alpha-btn");
    if (!btn) return;
    activeLetter = btn.dataset.letter;
    alphaFilter.querySelectorAll(".alpha-btn").forEach(b =>
      b.classList.toggle("active", b.dataset.letter === activeLetter));
    apply();
  });

  let timer;
  searchInput.addEventListener("input", e => {
    clearTimeout(timer);
    timer = setTimeout(() => {
      searchQ = e.target.value;
      // A search spans every letter, so reset the alphabet filter to All.
      activeLetter = "all";
      alphaFilter.querySelectorAll(".alpha-btn").forEach(b =>
        b.classList.toggle("active", b.dataset.letter === "all"));
      apply();
    }, 200);
  });

  // Deep link from the episodes page: ?guest=Name prefills the search.
  const guestParam = new URLSearchParams(window.location.search).get("guest");
  if (guestParam) {
    searchInput.value = guestParam;
    searchQ = guestParam;
    apply();
  }

  // Scroll to a specific guest anchor (#guest-lastname) and flash a highlight.
  if (window.location.hash) {
    const el = document.getElementById(window.location.hash.slice(1));
    if (el) {
      setTimeout(() => {
        el.scrollIntoView({ behavior: "smooth", block: "start" });
        el.style.outline = "3px solid var(--primary)";
        el.style.outlineOffset = "4px";
        el.style.borderRadius = "var(--radius-sm)";
        setTimeout(() => { el.style.outline = ""; el.style.outlineOffset = ""; }, 2000);
      }, 100);
    }
  }
})();
</script>
{% endblock %}
