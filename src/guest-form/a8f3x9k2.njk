---

<meta name="robots" content="noindex">

<div class="page-header">
  <div class="container">
    <h1>Bendy Bodies Podcast &mdash; Guest Information</h1>
    <p>Welcome! Please fill in your information for your upcoming Bendy Bodies Podcast episode.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="form-card" id="guestFormCard">

      <div class="form-alert form-alert-info">
        <svg class="form-alert-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div>
          This information will be used to create your episode page on our website. Please double-check your details before submitting.
        </div>
      </div>

      <form id="guestForm" action="#" method="POST" enctype="multipart/form-data">

        <div class="form-group">
          <label class="form-label" for="guest-name">Full name</label>
          <p class="form-hint">Your name as you'd like it displayed on the episode page.</p>
          <input class="form-input" type="text" id="guest-name" name="name" placeholder="e.g. Dr. Jane Smith" required>
        </div>

        <div class="form-group">
          <label class="form-label" for="guest-credentials">Credentials</label>
          <p class="form-hint">Degrees and certifications (e.g. MD, DPT, PhD, LCSW)</p>
          <input class="form-input" type="text" id="guest-credentials" name="credentials" placeholder="e.g. MD, FAAP" required>
        </div>

        <div class="form-group">
          <label class="form-label" for="guest-affiliation">Affiliation</label>
          <p class="form-hint">Your practice, hospital, organization, or university.</p>
          <input class="form-input" type="text" id="guest-affiliation" name="affiliation" placeholder="e.g. University of Wisconsin" required>
        </div>

        <div class="form-group">
          <label class="form-label" for="guest-bio">Professional bio</label>
          <p class="form-hint">A short biography (2&ndash;4 sentences) that will appear on your episode page.</p>
          <textarea class="form-textarea" id="guest-bio" name="bio" rows="5" placeholder="Tell listeners about your background, expertise, and what you're passionate about..." required></textarea>
        </div>

        <fieldset class="form-group form-socials-group">
          <legend class="form-label">Social &amp; web links <span class="optional">(optional)</span></legend>
          <p class="form-hint">Add your professional website and social media profiles.</p>

          <div class="social-input-row">
            <span class="social-input-icon" title="Website"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
            <input class="form-input" type="url" id="guest-website" name="website" placeholder="https://yourwebsite.com">
            <span class="social-input-label">Website</span>
          </div>

          <div class="social-input-row">
            <span class="social-input-icon" title="LinkedIn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></span>
            <input class="form-input" type="url" id="guest-linkedin" name="linkedin" placeholder="https://linkedin.com/in/yourprofile">
            <span class="social-input-label">LinkedIn</span>
          </div>

          <div class="social-input-row">
            <span class="social-input-icon" title="Twitter / X"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg></span>
            <input class="form-input" type="url" id="guest-twitter" name="twitter" placeholder="https://twitter.com/yourhandle">
            <span class="social-input-label">Twitter / X</span>
          </div>

          <div class="social-input-row">
            <span class="social-input-icon" title="Substack"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg></span>
            <input class="form-input" type="url" id="guest-substack" name="substack" placeholder="https://yourname.substack.com">
            <span class="social-input-label">Substack</span>
          </div>

          <details class="social-more-details">
            <summary class="social-more-toggle">More Socials</summary>
            <div class="social-more-fields">
              <div class="social-input-row">
                <span class="social-input-icon" title="Website 2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
                <input class="form-input" type="url" id="guest-website2" name="website2" placeholder="https://secondsite.com">
                <span class="social-input-label">Site 2</span>
              </div>

              <div class="social-input-row">
                <span class="social-input-icon" title="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></span>
                <input class="form-input" type="url" id="guest-facebook" name="facebook" placeholder="https://facebook.com/yourpage">
                <span class="social-input-label">Facebook</span>
              </div>

              <div class="social-input-row">
                <span class="social-input-icon" title="YouTube"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></span>
                <input class="form-input" type="url" id="guest-youtube" name="youtube" placeholder="https://youtube.com/@yourchannel">
                <span class="social-input-label">YouTube</span>
              </div>

              <div class="social-input-row">
                <span class="social-input-icon" title="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></span>
                <input class="form-input" type="url" id="guest-instagram" name="instagram" placeholder="https://instagram.com/yourhandle">
                <span class="social-input-label">Instagram</span>
              </div>

              <div class="social-input-row">
                <span class="social-input-icon" title="TikTok"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg></span>
                <input class="form-input" type="url" id="guest-tiktok" name="tiktok" placeholder="https://tiktok.com/@yourhandle">
                <span class="social-input-label">TikTok</span>
              </div>

              <div class="social-input-row">
                <span class="social-input-icon" title="Wikipedia"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.09 13.119c-.936 1.932-2.217 4.548-2.853 5.728-.616 1.074-1.127.914-1.5 0-.163-.401-2.199-5.237-4.1-9.87-.472-1.15-.795-1.252-1.44-1.34L1.5 7.5V7c1.094.04 1.645.06 2.784.068 1.14-.008 2.277-.03 3.09-.068v.5l-.495.1c-.576.114-.727.381-.517.932 1.142 3.012 2.304 5.835 2.304 5.835l2.204-4.568s-.705-1.59-1.124-2.587c-.322-.764-.604-.858-1.163-.936L7.5 6.1v-.5c1.02.04 2.01.06 2.97.068.94-.008 1.84-.03 2.7-.068v.5l-.5.1c-.582.126-.702.392-.468.972.704 1.754 1.476 3.626 1.476 3.626l1.41-2.857c.46-.937.39-1.396-.397-1.556L14.1 6.1v-.5c.85.04 1.62.06 2.37.068.76-.008 1.56-.03 2.38-.068v.5l-.55.112c-.773.158-1.14.64-1.74 1.706L14.02 12.86l2.07 4.26c1.78-3.614 3.532-7.228 3.532-7.228.56-1.144.26-1.486-.55-1.614L18.1 8.1v-.5c.87.04 1.64.06 2.34.068.76-.008 1.46-.03 2.06-.068v.5l-.42.084c-.6.12-.934.648-1.41 1.556L16.36 18.85c-.44.852-.71.916-1.12 0l-3.15-5.73z"/></svg></span>
                <input class="form-input" type="url" id="guest-wikipedia" name="wikipedia" placeholder="https://en.wikipedia.org/wiki/Your_Name">
                <span class="social-input-label">Wikipedia</span>
              </div>
            </div>
          </details>
        </fieldset>

        <div class="form-group">
          <label class="form-label" for="guest-headshot">Headshot photo</label>
          <p class="form-hint">A high-resolution professional photo for your episode page. Accepted formats: JPG, PNG, WEBP (max 10 MB).</p>
          <input class="form-input" type="file" id="guest-headshot" name="headshot" accept="image/jpeg,image/png,image/webp" required style="padding: 10px 16px;">
          <p class="form-hint" id="headshot-status" style="display: none; color: var(--primary); margin-top: 6px;"></p>
        </div>

        <div class="form-group">
          <label class="form-label" for="guest-anything">Anything else we should know? <span class="optional">(optional)</span></label>
          <textarea class="form-textarea" id="guest-anything" name="additional" rows="3" placeholder="Pronunciation of your name, preferred pronouns, topics to highlight, etc." style="min-height: 80px;"></textarea>
        </div>

        <div class="form-disclaimer">
          <div class="form-disclaimer-title">How we use your information</div>
          <div class="form-disclaimer-text">
            The information you provide will be used to create your episode page on the Bendy Bodies Podcast website, including your name, credentials, bio, photo, and any links you share. By submitting, you give permission for this information to be published on our website and used in promotional materials for the episode.
            This site is protected by reCAPTCHA and the Google <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a> and <a href="https://policies.google.com/terms" target="_blank" rel="noopener">Terms of Service</a> apply.
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="guestSubmitBtn">Submit Guest Information</button>
        </div>
      </form>

      <!-- Success state -->
      <div class="form-success" id="guestSuccess" style="display: none;">
        <div class="form-success-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2>Information received</h2>
        <p>Thank you! We have everything we need to create your episode page. The podcast team will reach out if we need anything else. We look forward to having you on the show!</p>
      </div>
    </div>
  </div>
</section>

{% block scripts %}
<script src="/js/form-submit.js"></script>
<script>
document.getElementById('guestForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('guestSubmitBtn');
  btn.disabled = true;
  btn.textContent = 'Uploading...';

  // Convert headshot to base64
  const fileInput = document.getElementById('guest-headshot');
  let headshotBase64 = '';
  let headshotMime = '';
  let headshotExt = '';
  if (fileInput.files.length > 0) {
    const file = fileInput.files[0];
    if (file.size > 10 * 1024 * 1024) {
      alert('Headshot file must be under 10 MB.');
      btn.disabled = false;
      btn.textContent = 'Submit Guest Information';
      return;
    }
    const status = document.getElementById('headshot-status');
    status.style.display = 'block';
    status.textContent = 'Uploading headshot...';
    headshotBase64 = await fileToBase64(file);
    headshotMime = file.type;
    headshotExt = file.name.split('.').pop().toLowerCase();
  }

  btn.textContent = 'Submitting...';

  try {
    // Collect social links into structured format
    const socialFields = [
      { id: 'guest-website', label: 'Website' },
      { id: 'guest-linkedin', label: 'LinkedIn' },
      { id: 'guest-twitter', label: 'Twitter' },
      { id: 'guest-substack', label: 'Substack' },
      { id: 'guest-website2', label: 'Site 2' },
      { id: 'guest-facebook', label: 'Facebook' },
      { id: 'guest-youtube', label: 'YouTube' },
      { id: 'guest-instagram', label: 'Instagram' },
      { id: 'guest-tiktok', label: 'TikTok' },
      { id: 'guest-wikipedia', label: 'Wikipedia' },
    ];
    const socialLinks = socialFields
      .map(f => { const v = document.getElementById(f.id).value.trim(); return v ? `${f.label}: ${v}` : ''; })
      .filter(Boolean).join('\n');

    await submitToSheet('guest_info', {
      name: document.getElementById('guest-name').value,
      credentials: document.getElementById('guest-credentials').value,
      affiliation: document.getElementById('guest-affiliation').value,
      bio: document.getElementById('guest-bio').value,
      website: document.getElementById('guest-website').value,
      social_links: socialLinks,
      additional: document.getElementById('guest-anything').value,
      headshot_base64: headshotBase64,
      headshot_mime: headshotMime,
      headshot_ext: headshotExt
    });
  } catch (err) {}

  document.getElementById('guestForm').style.display = 'none';
  document.querySelector('.form-alert').style.display = 'none';
  document.getElementById('guestSuccess').style.display = 'block';
  window.scrollTo({ top: document.getElementById('guestFormCard').offsetTop - 100, behavior: 'smooth' });
});
</script>
{% endblock %}
