---
layout: base.njk
title: "Contact Us"
activePage: "contact"
permalink: /contact/
---

<div class="page-header">
  <div class="container">
    <h1>Contact Us</h1>
    <p>Have a question or need to get in touch? We'd love to hear from you.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="form-card" id="contactFormCard">

      <!-- Disclaimer -->
      <div class="form-alert form-alert-warning">
        <svg class="form-alert-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div>
          <strong>Important:</strong> This form is for general inquiries only. We cannot provide medical advice, diagnoses, treatment recommendations, or legal counsel through this form. For medical concerns, please contact your healthcare provider. If you are in crisis, call 988 (Suicide &amp; Crisis Lifeline) or go to your nearest emergency room.
        </div>
      </div>

      <form id="contactForm" action="#" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="contact-first">First name</label>
            <input class="form-input" type="text" id="contact-first" name="first_name" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-last">Last name</label>
            <input class="form-input" type="text" id="contact-last" name="last_name" required>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-email">Email</label>
          <input class="form-input" type="email" id="contact-email" name="email" required>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-subject">Subject</label>
          <select class="form-select" id="contact-subject" name="subject" required>
            <option value="" disabled selected>Select a topic</option>
            <option value="coaching">Education &amp; Coaching</option>
            <option value="medical">Medical Services</option>
            <option value="mentorship">Professional Mentorship</option>
            <option value="medico-legal">Medico-Legal Consulting</option>
            <option value="podcast">Podcast</option>
            <option value="billing">Billing &amp; Payment</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-message">Message</label>
          <textarea class="form-textarea" id="contact-message" name="message" placeholder="How can we help?" rows="6" required></textarea>
        </div>

        <div class="form-disclaimer">
          <div class="form-disclaimer-title">Privacy notice</div>
          <div class="form-disclaimer-text">
            Your information is used solely to respond to your inquiry and is never shared with third parties. This form does not establish a patient-provider or attorney-client relationship.
            This site is protected by reCAPTCHA and the Google <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a> and <a href="https://policies.google.com/terms" target="_blank" rel="noopener">Terms of Service</a> apply.
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="contactSubmitBtn">Send Message</button>
        </div>
      </form>

      <!-- Success state -->
      <div class="form-success" id="contactSuccess" style="display: none;">
        <div class="form-success-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2>Message sent</h2>
        <p>Thank you for reaching out. We'll get back to you as soon as possible.</p>
      </div>
    </div>
  </div>
</section>

{% block scripts %}
<script src="/js/form-submit.js"></script>
<script>
document.getElementById('contactForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('contactSubmitBtn');
  btn.disabled = true;
  btn.textContent = 'Sending...';

  try {
    await submitToSheet('contact', {
      first_name: document.getElementById('contact-first').value,
      last_name: document.getElementById('contact-last').value,
      email: document.getElementById('contact-email').value,
      subject: document.getElementById('contact-subject').value,
      message: document.getElementById('contact-message').value
    });
  } catch (err) {
    // Submission still likely went through with no-cors
  }

  document.getElementById('contactForm').style.display = 'none';
  document.querySelector('.form-alert').style.display = 'none';
  document.getElementById('contactSuccess').style.display = 'block';
});
</script>
{% endblock %}
