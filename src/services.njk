{% block scripts %}
<script type="application/json" id="conditionsData">{{ conditions.conditions | dump | safe }}</script>
<script>
// ---- Interactive conditions explorer (data from CMS: conditions.json) ----
// Renders into every .cond-explorer on the page (coaching + medical). The
// detail card stays hidden until a condition is selected. Homepage links can
// deep-link with ?condition=<slug> to pre-select in the coaching instance.
(function() {
  const dataEl = document.getElementById('conditionsData');
  if (!dataEl) return;
  const CONDITIONS = JSON.parse(dataEl.textContent);

  function renderDetail(detail, c) {
    const epHref = c.tag ? '/podcast-episodes/?tag=' + encodeURIComponent(c.tag) : '/podcast-episodes/';
    detail.innerHTML =
      '<div class="cond-abbr">' + c.abbr + '</div>' +
      '<h3>' + c.name + '</h3>' +
      '<p>' + c.description + '</p>' +
      '<div class="cond-signals"><b>Common signals</b><ul>' +
        c.signals.map(s => '<li>' + s + '</li>').join('') +
      '</ul></div>' +
      '<div class="cond-actions">' +
        '<a class="btn btn-primary" href="' + epHref + '">Listen to related episodes &rarr;</a>' +
      '</div>';
    detail.hidden = false;
  }

  document.querySelectorAll('.cond-explorer').forEach(exp => {
    const detail = exp.querySelector('.cond-detail');
    exp.querySelectorAll('.cond-tag').forEach(btn => {
      btn.addEventListener('click', () => {
        exp.querySelectorAll('.cond-tag').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderDetail(detail, CONDITIONS[+btn.dataset.i]);
      });
    });
  });

  // Deep-link from the homepage: ?condition=<slug> selects it in the coaching
  // explorer and scrolls there.
  const cond = new URLSearchParams(location.search).get('condition');
  if (cond) {
    const exp = document.querySelector('.cond-explorer[data-cond-instance="coaching"]')
             || document.querySelector('.cond-explorer');
    const btn = exp && exp.querySelector('.cond-tag[data-key="' + cond.replace(/"/g, '') + '"]');
    if (btn) {
      btn.click();
      // Scroll after the detail card has rendered (which changes layout height).
      setTimeout(() => {
        const sec = document.getElementById('coaching');
        if (sec) sec.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 120);
    }
  }
})();

function copyAddress(text, btn) {
  navigator.clipboard.writeText(text).then(() => {
    const orig = btn.innerHTML;
    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
    setTimeout(() => { btn.innerHTML = orig; }, 2000);
  });
}
</script>
{% endblock %}
