---
layout: base.njk
title: "All Episodes"
activePage: "podcast"
extraCss: "podcast-styles.css"
bodyClass: "podcast-page"
podcastSubpage: "episodes"
permalink: /podcast-episodes/
---

{% include "podcast-subnav.njk" %}

<!-- Page Hero -->
<div class="podcast-page-hero">
  <div class="container">
    <div>
      <h1>All Episodes</h1>
      <p id="episodeCountHero">{{ collections.episodes.length }} episodes — Search by topic, guest, or keyword</p>
    </div>
    <div class="subscribe-buttons" style="margin: 0;">
