<!-- Search & Filter Bar -->
<div class="filter-bar" id="filterBar">
  <div class="filter-inner">
    <div class="search-row">
      <div class="search-box">
        <span class="search-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
        <input type="text" id="searchInput" placeholder="Search episodes, guests, topics..." autocomplete="off" spellcheck="false">
      </div>
      <select class="sort-select" id="searchScope">
        <option value="transcript">Search Transcript</option>
        <option value="title-desc">Search Title & Description</option>
        <option value="all">Search All</option>
      </select>
      <select class="sort-select" id="sortSelect">
        <option value="newest">Newest First</option>
        <option value="oldest">Oldest First</option>
      </select>
    </div>
    <div class="tag-row">
      <button class="tag-toggle-btn" id="tagToggle">
        <span>Tags</span>
        <svg class="tag-toggle-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="2,4 6,8 10,4"/></svg>
      </button>
      <span class="active-tag-label" id="activeTagLabel"></span>
    </div>
    <div class="tag-dropdown" id="tagDropdown" style="display:none;">
      <button class="filter-tag active" data-tag="all">All</button>
      <button class="filter-tag" data-tag="EDS">EDS</button>
      <button class="filter-tag" data-tag="POTS">POTS</button>
      <button class="filter-tag" data-tag="MCAS">MCAS</button>
      <button class="filter-tag" data-tag="Pain">Pain</button>
      <button class="filter-tag" data-tag="Nutrition">Nutrition</button>
      <button class="filter-tag" data-tag="Mental Health">Mental Health</button>
      <button class="filter-tag" data-tag="Exercise">Exercise</button>
      <button class="filter-tag" data-tag="Diagnosis">Diagnosis</button>
      <button class="filter-tag" data-tag="Treatment">Treatment</button>
      <button class="filter-tag" data-tag="Neurology">Neurology</button>
      <button class="filter-tag" data-tag="Genetics">Genetics</button>
      <button class="filter-tag" data-tag="Research">Research</button>
      <button class="filter-tag" data-tag="Surgery">Surgery</button>
    </div>
  </div>
</div>

<!-- Main Content -->
  <div class="container" style="padding-top: 24px; padding-bottom: 64px;">
    <div class="results-bar">
      <span class="results-count" id="resultsCount">Loading episodes...</span>
    </div>
    <div class="episode-grid" id="episodeGrid">
      <!-- Episodes rendered by JS -->
    </div>
    <div class="no-results" id="noResults" style="display:none;">
      <h3>No episodes found</h3>
      <p>Try a different search term or clear your filters.</p>
      <button class="btn btn-secondary" onclick="clearAll()" style="margin-top:16px; cursor:pointer;">Clear All Filters</button>
    </div>
  </div>

<!-- Episode Detail Modal -->
<div class="episode-modal-overlay" id="episodeModal">
  <div class="episode-modal">
    <div class="modal-header">
      <button class="modal-close" id="modalClose">&times;</button>
      <div class="modal-ep-num" id="modalEpNum"></div>
      <h2 class="modal-title" id="modalTitle"></h2>
      <div class="modal-guest-row">
        <div>
          <div class="modal-guest" id="modalGuest"></div>
          <div class="modal-meta" id="modalMeta"></div>
        </div>
        <div id="modalAvatars"></div>
      </div>
    </div>
    <div class="modal-body">
      <h4>Description</h4>
      <p class="modal-description" id="modalDescription"></p>

      <h4>Listen</h4>
      <div id="modalAudio" class="embed-placeholder">Audio player will appear here</div>

      <h4>Watch</h4>
      <div id="modalVideo" class="embed-placeholder">Video player will appear here</div>

      <div id="modalSnippetsSection" style="display:none;">
        <h4>Snippets</h4>
        <div class="snippets-grid" id="modalSnippets"></div>
      </div>

      <div id="modalTranscriptSection" style="display:none;">
        <h4>Transcript</h4>
        <div id="modalTranscript"></div>
      </div>

      <div id="modalGuestCardsSection" style="display:none;">
        <h4>Guests</h4>
        <div class="modal-guest-cards" id="modalGuestCards"></div>
      </div>

      <h4>Tags</h4>
      <div class="modal-tags" id="modalTags"></div>
    </div>
  </div>
</div>

{% block scripts %}
<script src="/js/data.js?v={{ "" | cacheBust }}"></script>
<script>
// ============================================
//  Episode Search & Filter Engine
// ============================================

let activeTag = 'all';
let searchQuery = '';
let sortMode = 'newest';
let searchScope = 'transcript';

const TAG_COLORS = {
  'EDS': '#4a2d7a', 'POTS': '#2a7a9d', 'MCAS': '#9d2a6b',
  'Pain': '#9d4a2a', 'Nutrition': '#2a7a4a', 'Mental Health': '#6b4a9d',
  'Exercise': '#2a5c9d', 'Diagnosis': '#7a5c2a', 'Treatment': '#2a9d8f',
  'Neurology': '#4a4a9d', 'Surgery': '#7a2a2a', 'Genetics': '#5c7a2a',
  'Hypermobility': '#4a2d7a', 'Research': '#2a4a7a',
};

function cleanTitle(title) {
  return title.replace(/\s*\((?:Ep|EP|BEN)\s*\d+\)\s*$/, '').replace(/^\d+\.\s+/, '').trim();
}

function formatDate(dateStr) {
  if (!dateStr) return '';
  try { return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); }
  catch (e) { return dateStr; }
}

const ABBREVS = /(?:Dr|Mr|Mrs|Ms|Prof|Sr|Jr|St|vs|etc|e\.g|i\.e|Vol|Ep|Inc|Ltd|M\.?D|Ph\.?D|D\.?P\.?T|P\.?A|R\.?D\.?N|O\.?T|P\.?T|J\.?D)\s*$/i;

function truncateAtSentence(text, maxChars) {
  if (!text || text.length <= maxChars) return text;
  const firstPara = text.split('\n\n')[0];
  if (firstPara.length <= maxChars) return firstPara;
  let lastGoodEnd = -1;
  for (let i = maxChars * 0.5; i < Math.min(firstPara.length, maxChars * 1.5); i++) {
    const ch = firstPara[i];
    if ((ch === '.' || ch === '!' || ch === '?') && (i + 1 >= firstPara.length || firstPara[i + 1] === ' ' || firstPara[i + 1] === '\n')) {
      const before = firstPara.substring(Math.max(0, i - 15), i + 1);
      if (!ABBREVS.test(before)) {
        lastGoodEnd = i + 1;
        if (i >= maxChars * 0.8) break;
      }
    }
  }
  if (lastGoodEnd > 0) return firstPara.substring(0, lastGoodEnd).trim();
  const cut = firstPara.substring(0, maxChars).lastIndexOf(' ');
  return firstPara.substring(0, cut > 0 ? cut : maxChars).trim() + '...';
}

function getGuestLastName(name) {
  let n = name.replace(/^(Dr\.?|Prof\.?|Professor)\s+/i, '');
  n = n.replace(/,?\s*(M\.?D\.?|Ph\.?D\.?|D\.?O\.?|D\.?P\.?T\.?|P\.?A\.?|R\.?D\.?N\.?|O\.?T\.?|P\.?T\.?|J\.?D\.?|D\.?C\.?|FACP|FACS|FACR|DO|PA-C|RN|NP|LCSW|LPC|BCPS|MPH)\.?\s*/gi, '');
  const parts = n.trim().split(/\s+/);
  return parts[parts.length - 1];
}

function resolveGuestImage(name) {
  let n = name.replace(/^(Dr\.?|Prof\.?|Professor)\s+/i, '');
  let prev;
  do {
    prev = n;
    n = n.replace(/[,\s]+(M\.?D\.?|Ph\.?D\.?|D\.?P\.?T\.?|D\.?O\.?|P\.?A\.?\-?C?|R\.?D\.?N\.?|O\.?T\.?|P\.?T\.?|J\.?D\.?|LICSW|NCPT|ATC|MS|MA|MPT|DMSC|MRCPsych|DDS|D\.?C\.?|FACP|FACS|FAANS|FAAFP|FAAN|FAMSSM|FACOG|FRCPC|IFMCP|ABIHM|CCSP|CEDS-S|FAED|CHT|CYT|CHC|CMTPT|COMT|NCS|OCS|CES|MHCM)\.?\s*$/i, '');
  } while (n !== prev);
  n = n.replace(/[,.\s]+$/, '').trim().toLowerCase();
  return GUEST_IMAGES[n] || null;
}

function getSocialIcon(url, size) {
  if (!url) return '';
  const s = size || 16;
  const u = url.toLowerCase();
  if (u.includes('wikipedia.org')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="currentColor"><path d="M12.09 13.119c-.936 1.932-2.217 4.548-2.853 5.728-.616 1.074-1.127.914-1.5 0-.163-.401-2.199-5.237-4.1-9.87-.472-1.15-.795-1.252-1.44-1.34L1.5 7.5V7c1.094.04 1.645.06 2.784.068 1.14-.008 2.277-.03 3.09-.068v.5l-.495.1c-.576.114-.727.381-.517.932 1.142 3.012 2.304 5.835 2.304 5.835l2.204-4.568s-.705-1.59-1.124-2.587c-.322-.764-.604-.858-1.163-.936L7.5 6.1v-.5c1.02.04 2.01.06 2.97.068.94-.008 1.84-.03 2.7-.068v.5l-.5.1c-.582.126-.702.392-.468.972.704 1.754 1.476 3.626 1.476 3.626l1.41-2.857c.46-.937.39-1.396-.397-1.556L14.1 6.1v-.5c.85.04 1.62.06 2.37.068.76-.008 1.56-.03 2.38-.068v.5l-.55.112c-.773.158-1.14.64-1.74 1.706L14.02 12.86l2.07 4.26c1.78-3.614 3.532-7.228 3.532-7.228.56-1.144.26-1.486-.55-1.614L18.1 8.1v-.5c.87.04 1.64.06 2.34.068.76-.008 1.46-.03 2.06-.068v.5l-.42.084c-.6.12-.934.648-1.41 1.556L16.36 18.85c-.44.852-.71.916-1.12 0l-3.15-5.73z"/></svg>`;
  if (u.includes('substack.com')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>`;
  if (u.includes('linkedin.com')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`;
  if (u.includes('twitter.com') || u.includes('x.com')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>`;
  if (u.includes('instagram.com')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`;
  if (u.includes('facebook.com')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`;
  if (u.includes('youtube.com') || u.includes('youtu.be')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`;
  if (u.includes('tiktok.com')) return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`;
  // Globe icon for external links
  return `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`;
}

function normalizeGuestKey(name) {
  let n = name.replace(/^(Dr\.?|Prof\.?|Professor)\s+/i, '');
  let prev;
  do {
    prev = n;
    n = n.replace(/[,\s]+(M\.?D\.?|Ph\.?D\.?|D\.?P\.?T\.?|D\.?O\.?|P\.?A\.?-?C?|R\.?D\.?N\.?|O\.?T\.?|P\.?T\.?|J\.?D\.?|LICSW|NCPT|ATC|MS|MA|MPT|DMSC|MRCPsych|DDS)\.?\s*$/i, '');
  } while (n !== prev);
  return n.replace(/[,.\s]+$/, '').trim().toLowerCase().replace(/\s+/g, ' ');
}

function guestSlug(name) {
  return normalizeGuestKey(name).replace(/\s+/g, '-');
}

function hasGuestPage(name) {
  return typeof GUEST_PROFILES !== 'undefined' && !!GUEST_PROFILES[normalizeGuestKey(name)];
}

function guestLink(name) {
  return hasGuestPage(name) ? `/guests/${guestSlug(name)}/` : `/podcast-guests/#guest-${getGuestLastName(name)}`;
}

function getGuestProfile(name) {
  if (typeof GUEST_PROFILES === 'undefined') return null;
  return GUEST_PROFILES[normalizeGuestKey(name)] || null;
}

function buildModalGuestCard(name) {
  const img = resolveGuestImage(name);
  const profile = getGuestProfile(name);
  const imgHtml = img ? `<img class="guest-card-img" src="${img}" alt="${name}">` : '';
  const affiliationHtml = profile && profile.affiliation
    ? `<div class="guest-card-affiliation">${profile.affiliation}</div>` : '';
  const bioHtml = profile && profile.bio
    ? `<div class="guest-card-bio">${profile.bio}</div>` : '';
  const linksHtml = profile && profile.links && profile.links.length
    ? profile.links.map(l => `<a href="${l.url}" target="_blank" rel="noopener" class="guest-card-website" title="${l.label || 'Website'}">${getSocialIcon(l.url)}</a>`).join(' ')
    : '';
  const href = guestLink(name);
  return `
  <div class="guest-card">
    <div class="guest-card-header">
      ${imgHtml}
      <h3><a href="${href}" style="color:inherit;text-decoration:none;">${name}</a> ${linksHtml}</h3>
    </div>
    ${affiliationHtml}
    ${bioHtml}
  </div>`;
}

function buildAvatarHtml(ep, linkable, showAll) {
  if (!ep.guests || ep.guests.length === 0) return '';
  const guestsWithImages = ep.guests.map(g => ({ name: g, src: resolveGuestImage(g) })).filter(x => x.src);
  if (guestsWithImages.length === 0) return '';
  const MAX_SHOW = showAll ? guestsWithImages.length : 2;
  const isMulti = guestsWithImages.length > 1 && !showAll;
  let html = guestsWithImages.slice(0, MAX_SHOW).map((g) => {
    const img = `<img class="guest-avatar-img" src="${g.src}" alt="">`;
    if (linkable) {
      return `<a href="${guestLink(g.name)}" title="${g.name}" onclick="event.stopPropagation();">${img}</a>`;
    }
    return img;
  }).join('');
  if (guestsWithImages.length > MAX_SHOW) {
    html += `<span class="guest-avatar-overflow">+${guestsWithImages.length - MAX_SHOW}</span>`;
  }
  const classes = showAll ? 'guest-avatars modal-avatars-all' : `guest-avatars${isMulti ? ' multi' : ''}`;
  return `<div class="${classes}">${html}</div>`;
}

function buildCard(ep) {
  const tagChips = ep.tags.slice(0, 3).map(t => {
    const color = TAG_COLORS[t] || '#4a2d7a';
    return `<span class="tag-chip" style="background:${color}18; color:${color}; border-color:${color}30;">${t}</span>`;
  }).join('');

  const epNum = ep.num ? `<div class="ep-number">${ep.num}</div>` : '';
  const guestStr = ep.guests && ep.guests.length ? ep.guests.join(', ') : '';
  const isMulti = ep.guests && ep.guests.length > 1;
  const guestLine = guestStr ? `<div class="guest-name${isMulti ? ' multi-guest' : ''}">with ${guestStr}</div>` : '';
  const meta = [ep.date ? formatDate(ep.date) : '', ep.duration].filter(Boolean).join(' · ');
  const idx = EPISODES.indexOf(ep);
  const q = searchQuery.trim();
  const isSearching = !!q;
  const showTitleHighlight = isSearching && (searchScope === 'title-desc' || searchScope === 'all');
  const showTranscriptSnippets = isSearching && (searchScope === 'transcript' || searchScope === 'all');

  // Highlight title when searching title/description
  const titleHtml = showTitleHighlight ? highlightText(cleanTitle(ep.title), q) : cleanTitle(ep.title);
  const descText = truncateAtSentence(ep.description, 280);
  const descHtml = showTitleHighlight ? highlightText(descText, q) : descText;

  // Show transcript snippets when searching transcript
  let snippetsHtml = '';
  if (showTranscriptSnippets && ep.transcript) {
    const snippets = getTranscriptSnippets(ep.transcript, q, 3);
    if (snippets.length > 0) {
      snippetsHtml = '<div class="card-transcript-snippets">' +
        snippets.map(s => {
          const truncated = s.length > 200 ? s.substring(0, 200).trim() + '...' : s;
          return `<div class="card-transcript-snippet">${highlightText(truncated, q)}</div>`;
        }).join('') + '</div>';
    }
  }

  return `
  <article class="episode-card" onclick="openEpisode(${idx})">
    <div class="card-header">
      ${epNum}
      <div class="card-header-text">
        ${guestLine}
        <h3>${titleHtml}</h3>
      </div>
      ${buildAvatarHtml(ep)}
    </div>
    <div class="card-body">
      <p class="card-description">${descHtml}</p>
      ${snippetsHtml}
      <div class="card-tags">${tagChips}</div>
    </div>
    <div class="card-footer">
      <span class="card-meta">${meta}</span>
      <div class="card-footer-actions">
        ${ep.videoUrl ? `<span class="btn-watch" onclick="event.stopPropagation();openEpisodeVideo(${idx})">Watch</span>` : ''}
        <span class="btn-listen">Listen</span>
      </div>
    </div>
  </article>`;
}

// Strip HTML tags from transcript for plain-text search
function stripHtml(html) {
  if (!html) return '';
  return html.replace(/<[^>]+>/g, ' ').replace(/&[a-z]+;/g, ' ').replace(/\s+/g, ' ').trim();
}

// Extract a ~150-char window around each match occurrence in plain text
function extractWindows(plain, words, max) {
  const plainLower = plain.toLowerCase();
  const results = [];
  const usedPositions = [];
  // Find positions of word-start matches first, then substring matches
  const positions = [];
  for (const w of words) {
    const escaped = w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    // Word-start matches (higher priority)
    const reExact = new RegExp('(?:^|\\W)(' + escaped + '\\w*)', 'gi');
    let m;
    while ((m = reExact.exec(plainLower)) !== null) {
      positions.push({ pos: m.index, exact: true });
    }
    // Substring matches
    let idx = plainLower.indexOf(w);
    while (idx !== -1) {
      positions.push({ pos: idx, exact: false });
      idx = plainLower.indexOf(w, idx + 1);
    }
  }
  // Sort: exact first, then by position
  positions.sort((a, b) => (b.exact - a.exact) || (a.pos - b.pos));

  for (const { pos } of positions) {
    if (results.length >= max) break;
    // Skip if too close to an already-used position
    if (usedPositions.some(p => Math.abs(p - pos) < 120)) continue;
    usedPositions.push(pos);
    // Extract window around match
    let start = Math.max(0, pos - 60);
    let end = Math.min(plain.length, pos + 90);
    // Snap to word boundaries
    if (start > 0) { const sp = plain.indexOf(' ', start); if (sp !== -1 && sp < start + 15) start = sp + 1; }
    if (end < plain.length) { const sp = plain.lastIndexOf(' ', end); if (sp > end - 15) end = sp; }
    let snippet = plain.substring(start, end).trim();
    if (start > 0) snippet = '...' + snippet;
    if (end < plain.length) snippet += '...';
    results.push(snippet);
  }
  return results;
}

// Extract up to 3 sentence-level snippets from transcript matching query
// Scores each sentence and returns the best matches:
//   3 = word-start match (e.g. "test" in "tests")
//   2 = exact phrase match (multi-word)
//   1 = substring match (e.g. "test" in "gastrointestinal")
// Falls back to text-window extraction if sentence splitting finds nothing
function getTranscriptSnippets(transcript, query, maxSnippets) {
  if (!transcript || !query) return [];
  const plain = stripHtml(transcript);
  const words = query.toLowerCase().split(/\s+/).filter(Boolean);
  const plainLower = plain.toLowerCase();
  const max = maxSnippets || 3;

  // Check if any match exists at all
  if (!wordsMatch(plainLower, words)) return [];

  // Split into sentences (rough heuristic — try multiple patterns)
  let sentences = plain.split(/(?<=[.!?])\s+(?=[A-Z])/);
  // If splitting produced very few long chunks, try splitting on speaker labels too
  if (sentences.length < 5 && plain.length > 500) {
    sentences = plain.split(/(?<=[.!?])\s+(?=[A-Z])|(?<=\.\s)(?=[A-Z])|(?:\n+)|(?:(?:^|\s)[A-Z][a-z]+ [A-Z][a-z]+:\s)/);
    sentences = sentences.filter(s => s && s.trim().length > 10);
  }

  const scored = [];
  for (const s of sentences) {
    const sLower = s.toLowerCase();
    let snippetScore = 0;

    if (allExactWords(s, words))                      snippetScore = 3;
    else if (words.length > 1 && sLower.includes(query.toLowerCase())) snippetScore = 2;
    else if (wordsMatch(sLower, words))               snippetScore = 1;

    if (snippetScore > 0) scored.push({ text: s.trim(), score: snippetScore });
  }

  // Sort by score descending, take top N
  scored.sort((a, b) => b.score - a.score);
  const seen = new Set();
  const results = [];
  for (const item of scored) {
    if (results.length >= max) break;
    if (!seen.has(item.text)) {
      seen.add(item.text);
      results.push(item.text);
    }
  }

  // Fallback: if sentence splitting found nothing, extract text windows around matches
  if (results.length === 0) {
    return extractWindows(plain, words, max);
  }
  return results;
}

// Highlight query text within a string (HTML-safe)
// Highlights each individual word for non-consecutive matching
function highlightText(text, query) {
  if (!query) return text;
  let safe = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const words = query.split(/\s+/).filter(Boolean);
  for (const word of words) {
    const escaped = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const re = new RegExp('(' + escaped + ')', 'gi');
    safe = safe.replace(re, '<mark>$1</mark>');
  }
  return safe;
}

// Check if ALL query words appear in text (non-consecutive, any order)
function wordsMatch(text, words) {
  return words.every(w => text.includes(w));
}

// Check if query appears as a word-start match (not buried inside another word)
// "test" matches "test", "tests", "testing" but NOT "gastrointestinal" or "greatest"
function hasExactWord(text, word) {
  const escaped = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const re = new RegExp('(?:^|\\W)' + escaped + '(?:\\w*?)(?:$|\\W)', 'i');
  return re.test(text);
}

// Check if ALL query words appear as exact whole words
function allExactWords(text, words) {
  return words.every(w => hasExactWord(text, w));
}

// Score an episode for relevance ranking
// Higher score = more relevant. 0 = no match.
// Search scope controls which fields are searched:
//   'transcript' (default) — guest name + transcript
//   'title-desc' — guest name + title + description
//   'all' — all fields
function scoreEpisode(ep, queryStr) {
  const q = queryStr.toLowerCase();
  const words = q.split(/\s+/).filter(Boolean);
  let score = 0;

  const titleLower = ep.title.toLowerCase();
  const guestStr = (ep.guests || []).join(' ').toLowerCase();
  const descLower = ep.description.toLowerCase();
  const transcriptPlain = ep.transcript ? stripHtml(ep.transcript).toLowerCase() : '';

  const includeTranscript = searchScope === 'transcript' || searchScope === 'all';
  const includeTitleDesc = searchScope === 'title-desc' || searchScope === 'all';

  // --- Guest Name matches (always searched, highest priority: 1000+) ---
  if (words.length === 1) {
    if (hasExactWord(guestStr, words[0]))       score += 1200;
    else if (guestStr.includes(words[0]))        score += 1000;
  } else {
    if (allExactWords(guestStr, words))          score += 1200;
    else if (wordsMatch(guestStr, words))        score += 1000;
  }

  // --- Transcript matches (primary when in transcript/all mode) ---
  if (includeTranscript && transcriptPlain) {
    if (words.length === 1) {
      if (hasExactWord(transcriptPlain, words[0]))  score += 600;
      else if (transcriptPlain.includes(words[0]))  score += 400;
    } else {
      if (transcriptPlain.includes(q))               score += 700;
      else if (allExactWords(transcriptPlain, words)) score += 600;
      else if (wordsMatch(transcriptPlain, words))   score += 400;
    }
  }

  // --- Title matches (primary when in title-desc/all mode) ---
  if (includeTitleDesc) {
    if (words.length === 1) {
      if (hasExactWord(titleLower, words[0]))      score += 600;
      else if (titleLower.includes(words[0]))      score += 400;
    } else {
      if (titleLower.includes(q))                  score += 700;
      else if (allExactWords(titleLower, words))   score += 600;
      else if (wordsMatch(titleLower, words))      score += 400;
    }
  }

  // --- Description matches (when in title-desc/all mode) ---
  if (includeTitleDesc) {
    if (words.length === 1) {
      if (hasExactWord(descLower, words[0]))        score += 75;
      else if (descLower.includes(words[0]))        score += 50;
    } else {
      if (descLower.includes(q))                    score += 75;
      else if (wordsMatch(descLower, words))        score += 50;
    }
  }

  return score;
}

function getFilteredSorted() {
  let list = EPISODES.slice();
  if (activeTag !== 'all') list = list.filter(ep => ep.tags.includes(activeTag));
  if (searchQuery.trim()) {
    const q = searchQuery.trim();
    // Score and filter
    list = list.map(ep => ({ ep, score: scoreEpisode(ep, q) }))
               .filter(x => x.score > 0)
               .sort((a, b) => {
                 if (b.score !== a.score) return b.score - a.score;
                 // Tiebreak by date
                 return sortMode === 'oldest'
                   ? new Date(a.ep.date) - new Date(b.ep.date)
                   : new Date(b.ep.date) - new Date(a.ep.date);
               })
               .map(x => x.ep);
  } else {
    list.sort((a, b) => sortMode === 'oldest'
      ? new Date(a.date) - new Date(b.date)
      : new Date(b.date) - new Date(a.date)
    );
  }
  return list;
}

function renderEpisodes() {
  const grid = document.getElementById('episodeGrid');
  const noResults = document.getElementById('noResults');
  const countEl = document.getElementById('resultsCount');
  const list = getFilteredSorted();

  if (list.length === 0) {
    grid.innerHTML = '';
    noResults.style.display = 'block';
    countEl.innerHTML = '<strong>0</strong> episodes found';
    return;
  }

  noResults.style.display = 'none';
  grid.innerHTML = list.map(buildCard).join('');
  countEl.innerHTML = `Showing <strong>${list.length}</strong> of <strong>${EPISODES.length}</strong> episodes`;
}

function clearAll() {
  searchQuery = '';
  activeTag = 'all';
  searchScope = 'transcript';
  document.getElementById('searchInput').value = '';
  document.getElementById('searchScope').value = 'transcript';
  document.querySelectorAll('.filter-tag').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.tag === 'all');
  });
  updateActiveTagLabel();
  renderEpisodes();
}

// ---- Event Listeners ----
let searchTimer;
document.getElementById('searchInput').addEventListener('input', function(e) {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => { searchQuery = e.target.value; renderEpisodes(); }, 180);
});

document.getElementById('sortSelect').addEventListener('change', function(e) {
  sortMode = e.target.value;
  renderEpisodes();
});

document.getElementById('searchScope').addEventListener('change', function(e) {
  searchScope = e.target.value;
  renderEpisodes();
});

document.querySelectorAll('.filter-tag').forEach(btn => {
  btn.addEventListener('click', function() {
    const tag = this.dataset.tag;
    activeTag = (tag === 'all') ? 'all' : (activeTag === tag ? 'all' : tag);
    document.querySelectorAll('.filter-tag').forEach(b => {
      b.classList.toggle('active',
        (activeTag === 'all' && b.dataset.tag === 'all') ||
        (activeTag !== 'all' && b.dataset.tag === activeTag)
      );
    });
    updateActiveTagLabel();
    renderEpisodes();
  });
});

// ---- Tag Dropdown Toggle ----
const tagToggle = document.getElementById('tagToggle');
const tagDropdown = document.getElementById('tagDropdown');
const activeTagLabelEl = document.getElementById('activeTagLabel');

tagToggle.addEventListener('click', () => {
  const isOpen = tagDropdown.style.display !== 'none';
  tagDropdown.style.display = isOpen ? 'none' : 'flex';
  tagToggle.classList.toggle('open', !isOpen);
});

function updateActiveTagLabel() {
  activeTagLabelEl.textContent = activeTag === 'all' ? '' : activeTag;
}

// ---- Episode Detail Modal ----
const modal = document.getElementById('episodeModal');

function openEpisode(idx) {
  const ep = EPISODES[idx];
  if (!ep) return;

  document.getElementById('modalEpNum').textContent = ep.num ? `Episode ${ep.num}` : '';
  const titleEl = document.getElementById('modalTitle');
  if (ep.num !== null && ep.num !== undefined) {
    titleEl.innerHTML = `<a href="/episodes/${ep.num}/" class="modal-title-link">${cleanTitle(ep.title)}</a>`;
  } else {
    titleEl.textContent = cleanTitle(ep.title);
  }
  const modalGuestEl = document.getElementById('modalGuest');
  if (ep.guests && ep.guests.length) {
    const guestLinks = ep.guests.map(g => {
      return `<a href="${guestLink(g)}" class="modal-guest-link">${g}</a>`;
    });
    modalGuestEl.innerHTML = `with ${guestLinks.join(', ')}`;
  } else {
    modalGuestEl.textContent = '';
  }
  document.getElementById('modalAvatars').innerHTML = buildAvatarHtml(ep, true, true);
  document.getElementById('modalMeta').textContent = [formatDate(ep.date), ep.duration].filter(Boolean).join(' · ');
  document.getElementById('modalDescription').innerHTML = ep.description.split('\n\n').map(p => `<p>${p}</p>`).join('');

  // Audio
  const audioEl = document.getElementById('modalAudio');
  if (ep.audioUrl) {
    audioEl.innerHTML = `<audio controls style="width:100%;" preload="none"><source src="${ep.audioUrl}" type="audio/mpeg">Your browser does not support audio.</audio>`;
    audioEl.className = '';
  } else {
    audioEl.innerHTML = 'Audio player will be embedded here';
    audioEl.className = 'embed-placeholder';
  }

  // Video
  const videoEl = document.getElementById('modalVideo');
  if (ep.videoUrl) {
    const vidEmbed = ep.videoUrl.replace('youtube.com/watch?v=', 'youtube.com/embed/')
                                .replace('youtube.com/shorts/', 'youtube.com/embed/')
                                .replace('youtu.be/', 'youtube.com/embed/');
    videoEl.innerHTML = `<div style="aspect-ratio:16/9;border-radius:var(--radius);overflow:hidden;"><iframe src="${vidEmbed}" style="width:100%;height:100%;border:none;" allowfullscreen loading="lazy"></iframe></div>`;
    videoEl.className = '';
  } else {
    videoEl.innerHTML = 'Video player will be embedded here';
    videoEl.className = 'embed-placeholder';
  }

  // Snippets
  const snippetsSection = document.getElementById('modalSnippetsSection');
  const snippetsEl = document.getElementById('modalSnippets');
  if (ep.snippets && ep.snippets.length > 0) {
    snippetsSection.style.display = 'block';
    snippetsEl.innerHTML = ep.snippets.map(url => {
      let embedUrl = url.replace('youtube.com/watch?v=', 'youtube.com/embed/')
                        .replace('youtube.com/shorts/', 'youtube.com/embed/')
                        .replace('youtu.be/', 'youtube.com/embed/');
      const sep = embedUrl.includes('?') ? '&' : '?';
      embedUrl += `${sep}origin=${encodeURIComponent(window.location.origin)}`;
      return `<div class="snippet-embed"><iframe src="${embedUrl}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe></div>`;
    }).join('');
  } else {
    snippetsSection.style.display = 'none';
  }

  // Transcript
  const transcriptSection = document.getElementById('modalTranscriptSection');
  const transcriptEl = document.getElementById('modalTranscript');
  if (ep.transcript) {
    transcriptSection.style.display = 'block';
    if (ep.transcript.startsWith('http')) {
      transcriptEl.innerHTML = `<a href="${ep.transcript}" target="_blank" class="transcript-link">View Full Transcript &rarr;</a>`;
    } else {
      transcriptEl.innerHTML = `<div class="transcript-content">${ep.transcript}</div>`;
    }
  } else {
    transcriptSection.style.display = 'none';
  }

  // Guest Cards
  const guestCardsSection = document.getElementById('modalGuestCardsSection');
  const guestCardsEl = document.getElementById('modalGuestCards');
  if (ep.guests && ep.guests.length > 0) {
    guestCardsSection.style.display = 'block';
    guestCardsEl.innerHTML = ep.guests.map(buildModalGuestCard).join('');
  } else {
    guestCardsSection.style.display = 'none';
  }

  // Tags
  document.getElementById('modalTags').innerHTML = ep.tags.map(t => {
    const color = TAG_COLORS[t] || '#4a2d7a';
    return `<span class="tag-chip" style="background:${color}18; color:${color}; border-color:${color}30;">${t}</span>`;
  }).join('');

  modal.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  modal.classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('modalClose').addEventListener('click', closeModal);
modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

// ---- Watch (Video-Only Modal) ----
function openEpisodeVideo(idx) {
  const ep = EPISODES[idx];
  if (!ep || !ep.videoUrl) return;
  // Open the full modal but scroll to video section
  openEpisode(idx);
  setTimeout(() => {
    const videoEl = document.getElementById('modalVideo');
    if (videoEl) videoEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }, 100);
}

// ---- Initial Render ----
document.getElementById('episodeCountHero').textContent = `${EPISODES.length} episodes — Search by topic, guest, or keyword`;
renderEpisodes();

// ---- Auto-open episode from URL param ----
const urlParams = new URLSearchParams(window.location.search);
const epParam = urlParams.get('ep');
if (epParam) {
  const epNum = parseInt(epParam, 10);
  const idx = EPISODES.findIndex(e => e.num === epNum);
  if (idx !== -1) openEpisode(idx);
}
</script>
