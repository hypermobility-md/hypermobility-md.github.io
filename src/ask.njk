---
layout: base.njk
title: "Ask the Podcast a Question"
activePage: "ask"
permalink: /ask/
ogImage: /assets/og-pages/ask.jpg
noAnalytics: true  # forms may collect PHI — no GTM/analytics here
description: "Submit a question for a future Bendy Bodies Podcast episode. Selected questions about EDS, hypermobility, and related conditions will be answered on-air."
---

<div class="page-header">
  <div class="container">
    <h1>Ask the Podcast</h1>
    <p>Submit a question for a future episode of the Bendy Bodies Podcast. Selected questions will be answered on-air.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="form-card" id="askFormCard">

      <div class="form-alert form-alert-warning">
        <svg class="form-alert-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#C4862B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div>
          <strong>Please keep your question general.</strong><br>
          Don't include your full name, diagnosis details, medical history, or other personal health information. Frame your question as a general topic. For example, <em>"What should EDS patients know about anesthesia?"</em> rather than <em>"I have vEDS and I'm having surgery next month&hellip;"</em>
        </div>
      </div>

      <form id="askForm" action="#" method="POST">

        <div class="form-group">
          <label class="form-label" id="ask-topic-label">Topic area</label>
          <div class="form-chips" id="topicChips" role="group" aria-labelledby="ask-topic-label">
            <button type="button" class="form-chip" data-value="Daily living & management">Daily living &amp; management</button>
            <button type="button" class="form-chip" data-value="Diagnosis & testing">Diagnosis &amp; testing</button>
            <button type="button" class="form-chip" data-value="Treatment options">Treatment options</button>
            <button type="button" class="form-chip" data-value="Exercise & physical therapy">Exercise &amp; physical therapy</button>
            <button type="button" class="form-chip" data-value="Mental health & coping">Mental health &amp; coping</button>
            <button type="button" class="form-chip" data-value="Cosmetic & elective procedures">Cosmetic &amp; elective procedures</button>
            <button type="button" class="form-chip" data-value="Medications & supplements">Medications &amp; supplements</button>
            <button type="button" class="form-chip" data-value="Pediatric concerns">Pediatric concerns</button>
            <button type="button" class="form-chip" data-value="Other">Other</button>
          </div>
          <input type="hidden" name="topic" id="askTopic">
        </div>

        <div class="form-group">
          <label class="form-label" for="askQuestion">Your question</label>
          <textarea class="form-textarea" id="askQuestion" name="question" rows="5" placeholder="Frame your question as a general topic (no personal health details needed)..." required></textarea>
          <div style="text-align: right; font-size: 0.78rem; color: var(--text-light); margin-top: 4px;" id="askCharCount">0 characters</div>
        </div>

        <div class="form-group" role="radiogroup" aria-labelledby="ask-attr-label">
          <label class="form-label" id="ask-attr-label">Name preference</label>
          <p class="form-hint">This controls how you'll be referred to if your question is selected.</p>

          <div class="form-option-card selected" data-attr="anonymous" onclick="selectAttribution('anonymous')">
            <input type="radio" name="attribution" value="anonymous" checked class="sr-only">
            <div>
              <div class="form-option-title">Anonymous</div>
              <div class="form-option-desc">Your question will be read without any name</div>
            </div>
          </div>

          <div class="form-option-card" data-attr="first_name" onclick="selectAttribution('first_name')">
            <input type="radio" name="attribution" value="first_name" class="sr-only">
            <div style="flex:1;">
              <div class="form-option-title">First name</div>
              <div class="form-option-desc">e.g. "Sarah asks&hellip;"</div>
              <input type="text" class="form-input" id="askFirstName" name="display_name" placeholder="Your first name" style="display:none; margin-top: 10px; width: 220px;">
            </div>
          </div>

          <div class="form-option-card" data-attr="alias" onclick="selectAttribution('alias')">
            <input type="radio" name="attribution" value="alias" class="sr-only">
            <div style="flex:1;">
              <div class="form-option-title">Alias</div>
              <div class="form-option-desc">Pick a nickname or handle</div>
              <input type="text" class="form-input" id="askAlias" name="alias" placeholder="Your alias or nickname" style="display:none; margin-top: 10px; width: 220px;">
            </div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="askEmail">Email <span class="optional">(optional)</span></label>
          <p class="form-hint">Only used if we need to follow up. Stored separately from your question and never shared.</p>
          <input class="form-input" type="email" id="askEmail" name="email" placeholder="you@example.com">
        </div>

        <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
          <label class="form-check">
            <input type="checkbox" id="askConsent" required>
            <span>I understand my question may be read and discussed on the Bendy Bodies Podcast in anonymized or attributed form (per my selection above). This is not a clinical interaction and any on-air discussion is for informational purposes only.</span>
          </label>
          <label class="form-check">
            <input type="checkbox" id="askAge" required>
            <span>I confirm I am 18 years of age or older.</span>
          </label>
          <label class="form-check">
            <input type="checkbox" id="askTerms" required>
            <span>I agree to the <a href="/legal/#verification-licensing" target="_blank" rel="noopener" onclick="event.stopPropagation()">Verification &amp; Licensing Terms</a>. This form is not intended to collect personal health information, but I understand and agree to the <a href="/legal/#hipaa" target="_blank" rel="noopener" onclick="event.stopPropagation()">HIPAA Release Terms</a>.</span>
          </label>
        </div>

        <div class="form-disclaimer">
          <div class="form-disclaimer-title">Privacy notice</div>
          <div class="form-disclaimer-text">
            Your submission is stored securely and reviewed by the podcast team only. Email addresses (if provided) are stored separately from question content and never shared. Submitted questions may be lightly edited for clarity before being discussed on-air. This form does not establish a patient-provider relationship. For medical advice, please consult your healthcare provider.          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="askSubmitBtn">Submit question</button>
        </div>
      </form>

      <!-- Success state -->
      <div class="form-success" id="askSuccess" style="display: none;">
        <div class="form-success-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2>Question submitted</h2>
        <p>Thank you for your question! If it's selected for the podcast, it will be credited as <strong id="successCredit">Anonymous</strong>. We'll reach out via email if we need any clarification.</p>
      </div>

      <p style="text-align: center; font-size: 0.78rem; color: var(--text-light); margin-top: 20px;" id="askFootnote">
        Questions are reviewed and selected at the podcast team's discretion. Not all submissions will be featured.
      </p>
    </div>
  </div>
</section>

{% block scripts %}
<script src="/js/form-submit.js"></script>
<script>
let askAttrVal = 'anonymous';

// Topic chips
document.querySelectorAll('#topicChips .form-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('#topicChips .form-chip').forEach(c => c.classList.remove('selected'));
    chip.classList.add('selected');
    document.getElementById('askTopic').value = chip.dataset.value;
  });
});

// Character count
const qField = document.getElementById('askQuestion');
qField.addEventListener('input', () => {
  document.getElementById('askCharCount').textContent = qField.value.length + ' characters';
});

// Attribution selection
function selectAttribution(val) {
  askAttrVal = val;
  document.querySelectorAll('.form-option-card').forEach(c => {
    const isSelected = c.dataset.attr === val;
    c.classList.toggle('selected', isSelected);
    c.querySelector('input[type="radio"]').checked = isSelected;
  });
  document.getElementById('askFirstName').style.display = val === 'first_name' ? 'block' : 'none';
  document.getElementById('askAlias').style.display = val === 'alias' ? 'block' : 'none';
}

// Keyboard support: radios are visually hidden but focusable, so arrow-key
// selection fires `change` and drives the same visual state as a click.
document.querySelectorAll('input[name="attribution"]').forEach(r => {
  r.addEventListener('change', () => { if (r.checked) selectAttribution(r.value); });
});

// Submit
document.getElementById('askForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('askSubmitBtn');
  btn.disabled = true;
  btn.textContent = 'Submitting...';

  const creditLabel = askAttrVal === 'anonymous' ? 'Anonymous'
    : askAttrVal === 'first_name' ? document.getElementById('askFirstName').value
    : document.getElementById('askAlias').value;

  try {
    await submitToSheet('podcast_question', {
      topic: document.getElementById('askTopic').value,
      question: qField.value,
      attribution: askAttrVal,
      display_name: creditLabel,
      email: document.getElementById('askEmail').value
    });
  } catch (err) {}

  document.getElementById('successCredit').textContent = creditLabel;
  document.getElementById('askForm').style.display = 'none';
  document.querySelector('.form-alert-warning').style.display = 'none';
  document.getElementById('askFootnote').style.display = 'none';
  document.getElementById('askSuccess').style.display = 'block';
});
</script>
{% endblock %}
