---
permalink: /js/data.js
---
// Bendy Bodies Podcast — Episode Data
// Auto-generated by 11ty from episode markdown files
// {{ collections.episodes.length }} episodes loaded
// Last built: {{ "now" | isoDate }}

// Guest name → photo lookup (normalized: strip Dr./Prof., strip credentials, lowercase)
const GUEST_IMAGES = {{ guestData.images | jsonify | safe }};

// Guest name → professional profile data
const GUEST_PROFILES = {{ guestData.profiles | jsonify | safe }};

const EPISODES = [
{%- for ep in collections.episodes %}
  {
    "num": {{ ep.data.num if ep.data.num else "null" }},
    "title": {{ ep.data.title | jsonify | safe }},
    "date": "{{ ep.data.date }}",
    "duration": "{{ ep.data.duration }}",
    "description": {{ ep.data.description | jsonify | safe }},
    "tags": {{ ep.data.tags | jsonify | safe }},
    "audioUrl": "{{ ep.data.audioUrl }}",
    "videoUrl": "{{ ep.data.videoUrl }}",
    "snippets": {{ ep.data.snippets | jsonify | safe }},
    "hasTranscript": {{ "true" if ep.content and ep.content | length > 10 else "false" }},
    "transcriptId": "{{ ep.data.num if ep.data.num else ep.page.fileSlug }}",
    "guests": {{ ep.data.guests | jsonify | safe }},
    "guestImages": {{ ep.data.guestImages | jsonify | safe }}
  }{% if not loop.last %},{% endif %}
{%- endfor %}
];
